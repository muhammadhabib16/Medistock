{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aplikasi Pengelolaan Obat Apotik",
  "version": "1.0.2",
  "identifier": "com.apotek.sistem",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Aplikasi Pengelolaan Obat Apotik",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "fixedRuntime",
        "path": "./WebView2Runtime"
      }
    }
  }
}
